# Set ONE of the following to enable LLM-powered queries:
# Get free key at https://console.groq.com
GROQ_API_KEY=

# OR: Get free key at https://ai.google.dev
GEMINI_API_KEY=

# Optional model overrides:
# GROQ_MODEL=llama3-8b-8192
# GEMINI_MODEL=gemini-1.5-flash

# Optional: override database path (defaults to <repo_root>/data/app.db)
# APP_DB_PATH=/path/to/your/app.db
